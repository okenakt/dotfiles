[
  // ======================================//
  // Action Shortcuts (Ctrl)              //
  // ======================================//
  {
    "key": "ctrl+up",
    "command": "cursorMove",
    "when": "editorTextFocus",
    "args": { "to": "prevBlankLine", "by": "wrappedLine" }
  },
  {
    "key": "ctrl+down",
    "command": "cursorMove",
    "when": "editorTextFocus",
    "args": { "to": "nextBlankLine", "by": "wrappedLine" }
  },
  {
    "key": "ctrl+pageup",
    "command": "cursorTop"
  },
  {
    "key": "ctrl+pagedown",
    "command": "cursorBottom"
  },
  {
    "key": "ctrl+d",
    "command": "editor.action.revealDefinition"
  },
  {
    "key": "ctrl+m",
    "command": "bookmarks.toggle"
  },
  {
    "key": "ctrl+home",
    "command": "bookmarks.jumpToPrevious"
  },
  {
    "key": "ctrl+end",
    "command": "bookmarks.jumpToNext"
  },
  {
    "key": "ctrl+r",
    "command": "editor.action.startFindReplaceAction",
    "when": "editorFocus && findWidgetVisible"
  },
  // ======================================//
  // Action Variants (Ctrl+Shift)         //
  // ======================================//
  {
    "key": "ctrl+shift+up",
    "command": "cursorMove",
    "when": "editorTextFocus",
    "args": { "to": "prevBlankLine", "select": true }
  },
  {
    "key": "ctrl+shift+down",
    "command": "cursorMove",
    "when": "editorTextFocus",
    "args": { "to": "nextBlankLine", "select": true }
  },
  {
    "key": "ctrl+shift+pageup",
    "command": "cursorTopSelect"
  },
  {
    "key": "ctrl+shift+pagedown",
    "command": "cursorBottomSelect"
  },
  {
    "key": "ctrl+shift+c",
    "command": "workbench.action.terminal.copySelection",
    "when": "terminalFocus && terminalTextSelected"
  },

  // ======================================//
  // App Context Control (Alt)            //
  // ======================================//
  {
    "key": "alt+up",
    "command": "workbench.action.navigateUp",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+down",
    "command": "workbench.action.navigateDown",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+left",
    "command": "workbench.action.navigateLeft",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+right",
    "command": "workbench.action.navigateRight",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+pageup",
    "command": "workbench.action.previousEditor",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+pagedown",
    "command": "workbench.action.nextEditor",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+enter",
    "command": "workbench.action.showCommands",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+f",
    "command": "workbench.action.toggleMaximizeEditorGroup",
    "when": "!terminalFocus && (activeEditorGroupEmpty || editorTextFocus || editorIsOpen)"
  },
  {
    "key": "alt+`",
    "command": "workbench.action.terminal.focus",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+`",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus"
  },
  {
    "key": "alt+=",
    "command": "workbench.action.increaseViewSize",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+-",
    "command": "workbench.action.decreaseViewSize",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+t",
    "command": "workbench.action.files.newUntitledFile",
    "when": "!terminalFocus"
  },

  // ======================================//
  // App Context Variants (Alt+Shift)     //
  // ======================================//
  {
    "key": "alt+shift+up",
    "command": "workbench.action.moveEditorToAboveGroup",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+shift+down",
    "command": "workbench.action.moveEditorToBelowGroup",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+shift+left",
    "command": "workbench.action.moveEditorToLeftGroup",
    "when": "!terminalFocus"
  },
  {
    "key": "alt+shift+right",
    "command": "workbench.action.moveEditorToRightGroup",
    "when": "!terminalFocus"
  },

  // ======================================//
  // Ctrl+Alt Assignments                 //
  // ======================================//
  {
    "key": "ctrl+alt+up",
    "command": "removeSecondaryCursors",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+down",
    "command": "editor.action.insertCursorBelow",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+alt+`",
    "command": "workbench.action.terminal.new"
  },

  // ======================================//
  // Terminal App Context                  //
  // ======================================//
  {
    "key": "alt+up",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;3A" }
  },
  {
    "key": "alt+down",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;3B" }
  },
  {
    "key": "alt+right",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;3C" }
  },
  {
    "key": "alt+left",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;3D" }
  },
  {
    "key": "ctrl+alt+up",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;7A" }
  },
  {
    "key": "ctrl+alt+down",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;7B" }
  },
  {
    "key": "ctrl+alt+right",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;7C" }
  },
  {
    "key": "ctrl+alt+left",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[1;7D" }
  },
  {
    "key": "alt+pageup",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[5;3~" }
  },
  {
    "key": "alt+pagedown",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b[6;3~" }
  },
  {
    "key": "alt+t",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001bt" }
  },
  {
    "key": "alt+f",
    "command": "workbench.action.toggleMaximizedPanel",
    "when": "terminalFocus"
  },
  {
    "key": "alt+=",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b=" }
  },
  {
    "key": "alt+shift+=",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b+" }
  },
  {
    "key": "alt+-",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b-" }
  },
  {
    "key": "alt+shift+-",
    "command": "workbench.action.terminal.sendSequence",
    "when": "terminalFocus",
    "args": { "text": "\u001b_" }
  },

  // ======================================//
  // Other                                //
  // ======================================//
  {
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": { "text": "\\\r\n" },
    "when": "terminalFocus"
  }
]
