{
  "model": "opus",
  "theme": "dark",
  "tui": "fullscreen",
  "alwaysThinkingEnabled": true,
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "codex@openai-codex": true,
    "telegram@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:medium.com)",
      "WebFetch(domain:stackoverflow.com)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(node:*)",
      "Bash(tsc:*)",
      "Bash(npx:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(poetry:*)",
      "Bash(uv:*)",
      "Bash(cargo:*)",
      "Bash(rustc:*)",
      "Bash(docker:*)"
    ],
    "ask": ["Bash(git push:*)", "Bash(curl:*)"],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(sudo:*)",
      "Bash(npm publish:*)",
      "Bash(yarn publish:*)",
      "Bash(poetry publish:*)",
      "Bash(uv publish:*)",
      "Bash(cargo publish:*)",
      "Bash(docker push:*)"
    ]
  }
}
